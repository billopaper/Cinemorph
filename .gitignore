cache/clips/*
!cache/clips/.gitkeep
cache/images/*
!cache/images/.gitkeep
cache/narration/*
!cache/narration/.gitkeep

# Rendered movie output — keep the folder, ignore the video
out/*
!out/.gitkeep

# Assistant memory (never committed)
memory/

